FROM python:3.14-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    fastapi==0.136.0 \
    uvicorn==0.46.0 \
    sqlalchemy==2.0.49 \
    asyncpg==0.31.0 \
    alembic==1.18.4 \
    pydantic==2.13.3 \
    pydantic-settings==2.14.0 \
    apscheduler==3.11.2 \
    httpx==0.28.1 \
    openai==2.32.0 \
    openpyxl==3.1.5 \
    pandas==3.0.2

COPY backend/ ./backend/
COPY alembic/ ./alembic/
COPY alembic.ini ./alembic.ini

EXPOSE 8000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
